{
  "id": "openai-native-web-search",
  "name": "OpenAI Native Web Search",
  "version": "0.1.0",
  "description": "Route OpenClaw web_search to OpenAI-compatible Responses API native web_search.",
  "providers": ["openai-native"],
  "contracts": {
    "webSearchProviders": ["openai-native"]
  },
  "configSchema": {
    "type": "object",
    "properties": {
      "enabled": { "type": "boolean" },
      "config": {
        "type": "object",
        "properties": {
          "webSearch": {
            "type": "object",
            "properties": {
              "apiKey": { "type": "string" },
              "baseUrl": { "type": "string" },
              "model": { "type": "string" },
              "timeoutSeconds": { "type": "number" }
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    },
    "additionalProperties": true
  }
}
